# Backend environment example
# Copy to backend/.env and replace every placeholder before using protected flows.
#
# DEMO MODE: For a safe public demo, only NODE_ENV, PORT, and DATABASE_URL are
# required. Leave all API keys as placeholders — endpoints degrade gracefully.
# NEVER set POLYMARKET_BUILDER_*, HYPERLIQUID_API_WALLET_PRIVATE_KEY, DFLOW_API_KEY,
# COINBASE_COMMERCE_*, HELIO_*, or ADMIN_API_KEY in a public demo.
# See docs/demo-mode.md for the full boundary reference.

NODE_ENV=development
PORT=3002
USE_LOCAL_ENV=true

# Frontend origins
FRONTEND_URL=http://localhost:3001
FRONTEND_LOCAL=http://localhost:5173

# App metadata
APP_NAME=PromptTrading Open
APP_URL=http://localhost:3001

# Data stores
DATABASE_URL=postgresql://postgres:password@localhost:5432/prompttrading

# Secret management
AWS_REGION=us-east-2
AWS_SECRET_NAME=your-app/secrets

# AI providers
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=your_openrouter_api_key
OPENAI_API_KEY=your_openai_api_key
PERPLEXITY_API_KEY=your_perplexity_api_key

# Search / reranking (optional)
EMBEDDING_PROVIDER=openrouter
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
COHERE_API_KEY=your_cohere_api_key
COHERE_RERANK_MODEL=rerank-multilingual-v3.0

# Privy
PRIVY_APP_ID=your_privy_app_id
PRIVY_APP_SECRET=your_privy_app_secret
PRIVY_AUTHORIZATION_PRIVATE_KEY=wallet-auth:your_privy_authorization_private_key

# Polymarket builder / encryption
POLYMARKET_BUILDER_API_KEY=your_polymarket_builder_api_key
POLYMARKET_BUILDER_SECRET=your_polymarket_builder_secret
POLYMARKET_BUILDER_PASSPHRASE=your_polymarket_builder_passphrase
POLYMARKET_ENCRYPTION_KEY=replace_with_a_64_char_hex_key

# DFlow / Solana
DFLOW_API_KEY=your_dflow_api_key
DFLOW_TRADE_API=https://a.quote-api.dflow.net
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Hyperliquid
USE_TESTNET=true
HYPERLIQUID_TESTNET_INFO_API=https://api.hyperliquid-testnet.xyz/info
HYPERLIQUID_TESTNET_EXCHANGE_API=https://api.hyperliquid-testnet.xyz/exchange
HYPERLIQUID_MAINNET_INFO_API=https://api.hyperliquid.xyz/info
HYPERLIQUID_MAINNET_EXCHANGE_API=https://api.hyperliquid.xyz/exchange
HYPERLIQUID_MAIN_ACCOUNT=0xYourMainAccount
HYPERLIQUID_API_WALLET_ADDRESS=0xYourApiWalletAddress
HYPERLIQUID_API_WALLET_PRIVATE_KEY=your_hyperliquid_api_wallet_private_key
DEFAULT_INITIAL_BALANCE=10000

# Recharge / subscription
PLATFORM_USDC_RECEIVER=0xYourReceiverAddress
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
BASE_RPC_URL=https://mainnet.base.org
OPTIMISM_RPC_URL=https://mainnet.optimism.io
POLYGON_RPC_URL=https://polygon-rpc.com
ETHEREUM_RPC_URL=https://eth.llamarpc.com
ADMIN_EMAILS=admin@example.com
ADMIN_API_KEY=replace_me
COINBASE_COMMERCE_API_KEY=your_coinbase_commerce_api_key
COINBASE_COMMERCE_WEBHOOK_SECRET=your_coinbase_commerce_webhook_secret
HELIO_API_KEY=your_helio_api_key
HELIO_SECRET_KEY=your_helio_secret_key
HELIO_WEBHOOK_SECRET=your_helio_webhook_secret
