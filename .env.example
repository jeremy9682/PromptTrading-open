# Frontend environment example
# Copy to .env at the repository root.
#
# DEMO MODE: For a safe public demo, only VITE_API_URL and VITE_API_BASE_URL
# are needed. Leave all other variables empty — the UI degrades gracefully.
# See docs/demo-mode.md for the full boundary reference.

VITE_API_URL=http://localhost:3002/api
VITE_API_BASE_URL=http://localhost:3002

# Third-party integrations (leave empty for demo-safe mode)
VITE_PRIVY_APP_ID=your_privy_app_id
VITE_PRIVY_SESSION_SIGNER_ID=your_privy_session_signer_id
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Optional chain / payment defaults (leave empty for demo-safe mode)
VITE_PLATFORM_RECEIVER=0xYourReceiverAddress
VITE_POLYGON_RPC_URL=https://polygon-rpc.com
VITE_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Backend variables live in backend/.env.example
